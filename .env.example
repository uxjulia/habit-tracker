NODE_ENV=development
PORT=3000

# Database (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Auth - CHANGE THIS to a long random string in production
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=30d

# Optional: skip first-run web wizard (uncomment and fill in to auto-create user)
# SETUP_USERNAME=admin
# SETUP_PASSWORD=your-secure-password
