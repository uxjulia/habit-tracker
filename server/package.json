{
  "name": "habit-tracker-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../.env -- node dist/index.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "db:studio": "dotenv -e ../.env -- prisma studio",
    "db:generate": "dotenv -e ../.env -- prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
